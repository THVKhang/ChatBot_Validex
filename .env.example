# ============================================================
# ChatBot Validex — Environment Variable Reference
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
# Options: auto | google | openai
LLM_PROVIDER=google

# Google Gemini (recommended — free tier available)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_NAME=models/gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# OpenAI (optional alternative)
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=google

# Enable live LLM calls (set 0 to use fallback template mode)
USE_LIVE_LLM=1

# ── Generation ───────────────────────────────────────────────
USE_STRUCTURED_OUTPUT=1

# ── Vector Store — PostgreSQL/pgvector ───────────────────────
USE_PGVECTOR_RETRIEVAL=1
PGVECTOR_TABLE=validex_knowledge
PGVECTOR_MIN_SIMILARITY=0.15
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# For LangChain PGVector mode (optional alternative):
# PGVECTOR_CONNECTION_STRING=postgresql+psycopg2://user:password@host:5432/dbname

# ── Embeddings ───────────────────────────────────────────────
# Set ALLOW_FAKE_EMBEDDINGS=1 only for local testing without a real embedding API
ALLOW_FAKE_EMBEDDINGS=0
FAKE_EMBEDDING_DIM=1536
GOOGLE_EMBEDDING_OUTPUT_DIMENSION=1536

# ── Vector Store — Pinecone (optional) ───────────────────────
USE_PINECONE_RETRIEVAL=0
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=default

# ── Retrieval tuning ─────────────────────────────────────────
TOP_K=3
TOP_K_SHORT_MIN=3
TOP_K_SHORT_MAX=4
TOP_K_MEDIUM_MIN=6
TOP_K_MEDIUM_MAX=8
TOP_K_LONG_MIN=10
TOP_K_LONG_MAX=12
DATA_PROCESSED_DIR=data/processed

# ── Hybrid Fallback ──────────────────────────────────────────
# 1 = use general LLM knowledge when RAG retrieval is insufficient
# 0 = strict "Need More Context" mode
ALLOW_HYBRID_FALLBACK=1

# ── Images — Unsplash ────────────────────────────────────────
USE_UNSPLASH_IMAGES=1
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_API_BASE=https://api.unsplash.com
UNSPLASH_TIMEOUT_SECONDS=8

# ── Quality Gate ─────────────────────────────────────────────
ENFORCE_QUALITY_GATE=1
MIN_SECTIONS=3
MIN_SOURCES_USED=1
MIN_DRAFT_CHARS=700

# ── Rate Limiting ────────────────────────────────────────────
USE_RATE_LIMIT=1
RATE_LIMIT_PER_MINUTE=30
USE_REDIS_RATE_LIMIT=0
REDIS_URL=redis://localhost:6379/0

# ── CORS & Sessions ──────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8000
# Session idle timeout in seconds (default: 1 hour)
SESSION_TTL_SECONDS=3600

# ── Agentic RAG (experimental) ───────────────────────────────
USE_AGENTIC_RAG=0
AGENT_MAX_ITERATIONS=4
VALIDEX_WEBSITE_URL=https://www.validex.com.au
TOOL_ALLOWED_DOMAINS=validex.com.au,www.validex.com.au,acic.gov.au,www.acic.gov.au,afp.gov.au,www.afp.gov.au,oaic.gov.au,www.oaic.gov.au

# ── Data paths ───────────────────────────────────────────────
METADATA_PATH=data/metadata/documents.json
REPORTS_PATH=data/reports/reports.json
INGEST_MODE=raw_sql

# ── Debugging ────────────────────────────────────────────────
# Set LOG_RAW_LLM_IO=0 to silence raw prompt/response debug logs
LOG_RAW_LLM_IO=0
METRICS_WINDOW_SIZE=200
